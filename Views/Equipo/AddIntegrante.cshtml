@model IdeasCreativasApp.ViewModels.AddIntegranteViewModel
@{
    ViewData["Title"] = "Añadir Integrante";
}

<div class="form-container">
    <div class="card" style="margin-top: 2rem;">
        <h2 style="text-align: center; margin-top: 0;">Añadir Integrante</h2>
        <p class="text-muted" style="text-align: center; margin-bottom: 2rem;">
            Ingresa las credenciales de tu equipo y selecciona al alumno que deseas invitar.
        </p>

        <form asp-action="AddIntegrante" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 1rem;"></div>

            <div class="form-group">
                <label asp-for="NombreDeEquipo">Nombre del Equipo</label>
                <input asp-for="NombreDeEquipo" placeholder="Ingresa el nombre del equipo..." />
                <span asp-validation-for="NombreDeEquipo" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Contraseña del Equipo</label>
                <input asp-for="Password" type="password" placeholder="Ingresa la contraseña..." />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group" style="padding-top: 1rem; border-top: 1px solid var(--border-color);">
                <label asp-for="AlumnoId">Selecciona el Alumno Libre</label>
                <select asp-for="AlumnoId" asp-items="Model.AlumnosDisponibles" style="height: auto; padding: 0.75rem;">
                    <option value="">-- Seleccionar --</option>
                </select>
                <span asp-validation-for="AlumnoId" class="text-danger"></span>
            </div>

            <button type="submit" class="btn" style="width: 100%; margin-top: 1rem;">Unir al Equipo</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
